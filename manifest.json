{
  "Name": "Soomfon SE (Patched)",
  "Description": "Device support plugin for Ajazz AKP03 (+variants)",
  "Author": "Andrey Viktorov",
  "Version": "0.7.5",
  "PluginUUID": "st.lynx.plugins.opendeck-akp03",
  "CodePathLin": "opendeck-akp03-linux",
  "CodePathMac": "opendeck-akp03-mac",
  "CodePathWin": "opendeck-akp03-win.exe",
  "Icon": "assets/icon",
  "Category": "Hardware",
  "OS": [
    { "Platform": "linux" },
    { "Platform": "mac", "MinimumVersion": "11.3" },
    { "Platform": "windows", "MinimumVersion": "10" }
  ],
  "Actions": [
    {
      "Name": "Knob Test",
      "UUID": "st.lynx.plugins.opendeck-akp03.knobtest",
      "Icon": "assets/icon",
      "States": [
        {
          "Image": "assets/icon"
        }
      ],
      "Controllers": ["Encoder"],
      "Encoder": {
        "layout": "$X1",
        "triggerDescription": {
          "rotate": "Rotate",
          "push": "Push",
          "touch": "Touch"
        }
      }
    },
    {
      "Name": "Button Test",
      "UUID": "st.lynx.plugins.opendeck-akp03.buttontest",
      "Icon": "assets/icon",
      "States": [
        {
          "Image": "assets/icon"
        }
      ],
      "Controllers": ["Keypad"],
      "SupportedInMultiActions": true
    }
    ],
  "Controllers": ["Keypad", "Encoder"],
  "DeviceNamespace": "s6",
  "Device": {
    "Type": 7,
    "Size": {
      "Columns": 3,
      "Rows": 3
    }
  }
}
